#!/usr/bin/env bash
#
# pre-commit — Git pre-commit hook for The Agency.
#
# Auto-validates agent files before each commit. If any staged .md files are
# agent definitions, runs lint-agents.sh on them. Blocks the commit on errors.
#
# Install:
#   cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
# Prefer Python lint (cross-platform), fall back to bash
if [[ -f "$REPO_ROOT/scripts/lint-agents.py" ]] && command -v python3 &>/dev/null; then
  LINTER_CMD=(python3 "$REPO_ROOT/scripts/lint-agents.py")
  SCORER_CMD=(python3 "$REPO_ROOT/scripts/score-agents.py")
  HAS_PYTHON=true
else
  LINTER_CMD=(bash "$REPO_ROOT/scripts/lint-agents.sh")
  HAS_PYTHON=false
fi

# --- Colour helpers ---
if [[ -t 1 && -z "${NO_COLOR:-}" && "${TERM:-}" != "dumb" ]]; then
  GREEN=$'\033[0;32m'
  YELLOW=$'\033[1;33m'
  RED=$'\033[0;31m'
  BOLD=$'\033[1m'
  RESET=$'\033[0m'
else
  GREEN=''; YELLOW=''; RED=''; BOLD=''; RESET=''
fi

echo ""
echo "${BOLD}=== The Agency Pre-Commit Hook ===${RESET}"

# --- Step 1: Collect staged .md files ---
STAGED_MD_FILES=()
while IFS= read -r -d '' f; do
  # Skip non-agent directories
  case "$f" in
    docs/*|examples/*|integrations/*|scripts/*|.github/*|README.md|README-zh.md|CONTRIBUTING*.md|CLAUDE.md|AGENTS.md|CHANGELOG.md|CODE_OF_CONDUCT.md|SECURITY.md|USE-CASES.md|ARCHITECTURE.md) continue ;;
    *.md) STAGED_MD_FILES+=("$f") ;;
  esac
done < <(git -C "$REPO_ROOT" diff --cached --name-only --diff-filter=ACMR -z 2>/dev/null || true)

# --- Step 2: Skip if no agent files are staged ---
if [[ ${#STAGED_MD_FILES[@]} -eq 0 ]]; then
  echo "No agent files staged — skipping validation."
  echo ""
  exit 0
fi

echo "Checking ${#STAGED_MD_FILES[@]} staged agent file(s)..."
echo ""

# --- Step 3: Run linter on staged files ---
# We copy each staged file to a temp location and lint that, so we check the
# staged version, not the working-tree version.
TEMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TEMP_DIR"' EXIT

PASS=0
FAIL=0

for f in "${STAGED_MD_FILES[@]}"; do
  # Does the file exist in the repo at all? (new files are staged, so check git)
  if ! git -C "$REPO_ROOT" show ":$f" &>/dev/null; then
    echo "  ${YELLOW}⚠${RESET}  $f — skipped (binary or empty)"
    continue
  fi

  # Extract staged version to temp
  TEMP_FILE="$TEMP_DIR/$f"
  mkdir -p "$(dirname "$TEMP_FILE")"
  git -C "$REPO_ROOT" show ":$f" > "$TEMP_FILE" 2>/dev/null || {
    echo "  ${YELLOW}⚠${RESET}  $f — could not extract staged version"
    continue
  }

  # Run lint-agents.sh on this file
  if "${LINTER_CMD[@]}" "$TEMP_FILE" &>/tmp/agency-precommit-lint.$$.log; then
    echo "  ${GREEN}OK${RESET}  $f — PASSED"
    PASS=$(( PASS + 1 ))
  else
    echo "  ${RED}FAIL${RESET} $f — FAILED"
    # Extract just ERROR lines from the linter output
    grep 'ERROR' /tmp/agency-precommit-lint.$$.log 2>/dev/null | while IFS= read -r errline; do
      echo "     $errline"
    done
    grep 'WARN' /tmp/agency-precommit-lint.$$.log 2>/dev/null | while IFS= read -r warnline; do
      echo "     $warnline"
    done
    FAIL=$(( FAIL + 1 ))
  fi
done

rm -f /tmp/agency-precommit-lint.$$.log

echo ""

# --- Step 4: Check if AGENTS.json needs updating ---
STAGED_AGENTS_JSON=false
if git -C "$REPO_ROOT" diff --cached --name-only 2>/dev/null | grep -qx 'AGENTS.json'; then
  STAGED_AGENTS_JSON=true
fi

if [[ "$STAGED_AGENTS_JSON" == "false" ]]; then
  echo "${YELLOW}WARNING: agent files changed but AGENTS.json not staged.${RESET}"
  echo "     Run: ${GREEN}./scripts/generate-index.sh && git add AGENTS.json${RESET}"
  echo ""
fi

# --- Step 5: Quality score check (Python only) ---
SCORE_FAIL=0
if [[ "$HAS_PYTHON" == "true" && ${#STAGED_MD_FILES[@]} -gt 0 ]]; then
  for f in "${STAGED_MD_FILES[@]}"; do
    TEMP_FILE="$TEMP_DIR/$f"
    if [[ -f "$TEMP_FILE" ]]; then
      if ! "${SCORER_CMD[@]}" --file "$TEMP_FILE" --no-freshness --threshold 5 &>/dev/null; then
        SCORE_FAIL=$(( SCORE_FAIL + 1 ))
      fi
    fi
  done
  if [[ $SCORE_FAIL -gt 0 ]]; then
    echo ""
    echo "${RED}Quality gate: ${SCORE_FAIL} agent(s) scored below 5/10${RESET}"
    echo "     Run: python scripts/score-agents.py --file <agent> --no-freshness"
  fi
fi

# --- Step 6: Result ---
echo "Results: ${GREEN}${PASS} passed lint${RESET}, ${RED}${FAIL} failed lint${RESET}"
if [[ "$HAS_PYTHON" == "true" ]]; then
  echo "         ${GREEN}$(( ${#STAGED_MD_FILES[@]} - SCORE_FAIL )) passed score${RESET}, ${RED}${SCORE_FAIL} failed score${RESET}"
fi
echo "         ${#STAGED_MD_FILES[@]} total"

if [[ $FAIL -gt 0 || $SCORE_FAIL -gt 0 ]]; then
  echo ""
  echo "${RED}Commit blocked. Fix errors or use: git commit --no-verify${RESET}"
  exit 1
else
  echo ""
  echo "${GREEN}All checks passed. Proceeding with commit.${RESET}"
  exit 0
fi
