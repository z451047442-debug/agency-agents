# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly mark source and content files
*.py text=auto eol=lf
*.md text=auto eol=lf
*.sh text=auto eol=lf
*.yml text=auto eol=lf
*.yaml text=auto eol=lf
*.json text=auto eol=lf
*.toml text=auto eol=lf
*.txt text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.drawio binary
